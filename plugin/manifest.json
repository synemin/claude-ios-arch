{
  "name": "claude-ios-arch",
  "version": "0.3.0",
  "displayName": "Claude iOS Arch",
  "description": "An agent plugin focused on helping users design, bootstrap, review, and evolve iOS apps with strong architecture and low technical debt.",
  "scope": "ios-app-development",
  "phase": "phase-1-ios-first",
  "platforms": ["ios"],
  "futurePlatforms": ["android", "flutter", "react-native"],
  "pluginType": "agent-plugin",
  "architecture": "core-plus-adapters",
  "tasks": [
    "architecture-design",
    "tech-selection",
    "directory-structure",
    "bootstrap",
    "architecture-review",
    "debt-check"
  ],
  "triggers": [
    "new ios app",
    "ios architecture",
    "swiftui or uikit",
    "ios tech stack",
    "ios directory structure",
    "ios app bootstrap",
    "ios architecture review",
    "ios debt check"
  ],
  "entrypoints": {
    "core": "../core/manifest.json",
    "adapters": {
      "claude-code": "../adapters/claude-code/manifest.json",
      "codex": "../adapters/codex/manifest.json"
    },
    "rules": [
      "../rules/ios-architecture.md",
      "../rules/ios-low-debt.md",
      "../rules/ios-tech-selection.md"
    ],
    "commands": [
      "../commands/ios-app-bootstrap.md",
      "../commands/ios-arch-review.md",
      "../commands/ios-debt-check.md",
      "../commands/ios-tech-decision.md"
    ],
    "skills": [
      "../skills/ios-app-bootstrap/SKILL.md",
      "../skills/ios-arch-review/SKILL.md",
      "../skills/ios-tech-decision/SKILL.md",
      "../skills/ios-debt-check/SKILL.md"
    ],
    "hooks": [
      "../hooks/ios_arch_guard.py"
    ],
    "templates": [
      "../templates/architecture-brief.md",
      "../templates/decision-memo.md",
      "../templates/debt-report.md"
    ],
    "examples": [
      "../examples/bootstrap-request.md",
      "../examples/review-request.md",
      "../examples/decision-request.md"
    ],
    "platformGuide": "../platforms/ios/guide.md"
  },
  "nonGoals": [
    "mcp-server",
    "generic-agent-framework",
    "full-xcode-project-generator"
  ]
}
